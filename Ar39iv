<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Impulsiveness V/S Innocence | DNATech Article #39</title>
  <meta name="description" content="Some emotions are felt to make you know the reality. A deep reflection on innocence, impulsiveness, and how society shapes us.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Lora:ital,wght@0,400;0,500;1,400;1,500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    :root {
      --cream:       #faf6f0;
      --cream2:      #f5ede0;
      --cream3:      #ede0cc;
      --warm-brown:  #7a5c3e;
      --soft-brown:  #a07850;
      --text-dark:   #2e2218;
      --text-mid:    #5a4030;
      --text-light:  #9a8070;
      --sage:        #7a9a7a;
      --sage-light:  #c8ddc8;
      --blush:       #d4907a;
      --blush-light: #f0d0c4;
      --border:      rgba(122,92,62,0.15);
      --shadow:      0 4px 24px rgba(122,92,62,0.10);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    body {
      font-family: 'Lora', Georgia, serif;
      background: var(--cream);
      color: var(--text-dark);
      line-height: 1.85;
      overflow-x: hidden;
    }

    /* ── SCROLLBAR ── */
    ::-webkit-scrollbar { width: 5px; }
    ::-webkit-scrollbar-track { background: var(--cream2); }
    ::-webkit-scrollbar-thumb { background: var(--cream3); border-radius: 3px; }
    ::-webkit-scrollbar-thumb:hover { background: var(--soft-brown); }

    /* ══════════════════════════════════════
       HEADER / NAV
    ══════════════════════════════════════ */
    .site-header {
      background: var(--cream);
      border-bottom: 1.5px solid var(--border);
      position: sticky;
      top: 0;
      z-index: 200;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .site-header.scrolled {
      box-shadow: 0 2px 18px rgba(122,92,62,0.10);
    }
    .site-header.hidden {
      transform: translateY(-100%);
    }
    .header-inner {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 2rem;
      height: 62px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .brand {
      display: flex;
      align-items: center;
      gap: 0.55rem;
      text-decoration: none;
      font-family: 'Playfair Display', serif;
      font-weight: 700;
      font-size: 1.35rem;
      color: var(--text-dark);
      letter-spacing: -0.02em;
    }
    .brand-icon {
      width: 36px;
      height: 36px;
      border-radius: 8px;
      overflow: hidden;
      border: 1.5px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--cream2);
      font-family: 'Playfair Display', serif;
      font-weight: 700;
      font-size: 1rem;
      color: var(--warm-brown);
    }
    .brand-icon img {
      width: 100%;
      height: 100%;
      object-fit: contain;
    }

    /* ══════════════════════════════════════
       BOTANICAL BANNER
    ══════════════════════════════════════ */
    .botanical-banner {
      width: 100%;
      height: 90px;
      overflow: hidden;
      background: var(--cream2);
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .botanical-svg {
      width: 100%;
      height: 100%;
      position: absolute;
      top: 0; left: 0;
    }

    /* ══════════════════════════════════════
       MAIN LAYOUT
    ══════════════════════════════════════ */
    .page-wrap {
      max-width: 1200px;
      margin: 0 auto;
      padding: 2.5rem 2rem 5rem;
      display: grid;
      grid-template-columns: 1fr 300px;
      gap: 3.5rem;
      align-items: start;
    }

    /* ══════════════════════════════════════
       ARTICLE
    ══════════════════════════════════════ */
    .article-col {}

    .article-category {
      display: inline-block;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.72rem;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--blush);
      margin-bottom: 0.75rem;
    }

    .article-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2rem, 5vw, 3rem);
      font-weight: 700;
      line-height: 1.2;
      color: var(--text-dark);
      margin-bottom: 1rem;
      letter-spacing: -0.02em;
    }

    .article-meta {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.82rem;
      color: var(--text-light);
      margin-bottom: 2rem;
      flex-wrap: wrap;
    }
    .article-meta .sep { opacity: 0.4; }
    .article-meta .badge {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      background: var(--blush-light);
      color: var(--warm-brown);
      padding: 0.2rem 0.7rem;
      border-radius: 20px;
      font-size: 0.72rem;
      font-weight: 500;
    }

    /* Hero image + lead grid */
    .article-lead {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.25rem;
      margin-bottom: 2rem;
    }
    .article-lead-img {
      border-radius: 14px;
      overflow: hidden;
      height: 220px;
      background: var(--cream3);
      position: relative;
    }
    .article-lead-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: saturate(0.9) brightness(0.97);
      transition: transform 0.5s ease;
    }
    .article-lead-img:hover img { transform: scale(1.04); }

    .article-lead-right {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }
    .pull-quote-box {
      background: var(--blush-light);
      border-left: 3.5px solid var(--blush);
      border-radius: 0 12px 12px 0;
      padding: 1.1rem 1.3rem;
      font-family: 'Lora', serif;
      font-style: italic;
      font-size: 0.97rem;
      color: var(--warm-brown);
      line-height: 1.7;
      flex: 1;
    }
    .article-lead-img2 {
      border-radius: 12px;
      overflow: hidden;
      flex: 1;
      min-height: 100px;
      background: var(--cream3);
    }
    .article-lead-img2 img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: saturate(0.85);
    }

    /* Body text */
    .article-body {
      font-size: 1.05rem;
      color: var(--text-mid);
      line-height: 2;
    }

    /* Drop cap */
    .article-body .drop-cap::first-letter {
      float: left;
      font-family: 'Playfair Display', serif;
      font-size: 4.2em;
      font-weight: 700;
      line-height: 0.75;
      margin: 0.08em 0.1em 0 0;
      color: var(--warm-brown);
    }

    .article-body p {
      margin-bottom: 1.5rem;
    }

    .article-body p:first-child {
      font-size: 1.12rem;
    }

    /* Pull quote inline */
    .inline-quote {
      margin: 2rem 0;
      padding: 1.5rem 2rem;
      border-top: 2px solid var(--blush);
      border-bottom: 2px solid var(--blush);
      font-family: 'Playfair Display', serif;
      font-style: italic;
      font-size: 1.25rem;
      color: var(--warm-brown);
      text-align: center;
      line-height: 1.6;
      position: relative;
    }
    .inline-quote::before {
      content: '\201C';
      font-size: 4rem;
      color: var(--blush-light);
      position: absolute;
      top: -0.5rem;
      left: 1.5rem;
      font-family: 'Playfair Display', serif;
      line-height: 1;
    }

    /* Section heading inside article */
    .article-body h2 {
      font-family: 'Playfair Display', serif;
      font-size: 1.5rem;
      font-weight: 600;
      color: var(--text-dark);
      margin: 2.5rem 0 1rem;
      letter-spacing: -0.01em;
    }
    .article-body h2::after {
      content: '';
      display: block;
      width: 40px;
      height: 2px;
      background: var(--blush);
      margin-top: 0.4rem;
      border-radius: 2px;
    }

    /* Highlight box */
    .highlight-box {
      background: var(--sage-light);
      border-radius: 14px;
      padding: 1.4rem 1.6rem;
      margin: 2rem 0;
      font-size: 0.98rem;
      color: var(--text-dark);
      border-left: 4px solid var(--sage);
      line-height: 1.8;
    }
    .highlight-box strong {
      color: var(--warm-brown);
    }

    /* Article number stamp */
    .article-stamp {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      background: var(--cream2);
      border: 1.5px solid var(--border);
      border-radius: 10px;
      padding: 0.7rem 1.1rem;
      margin: 2rem 0 0;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.82rem;
      color: var(--text-light);
    }
    .article-stamp span { font-weight: 600; color: var(--warm-brown); }

    /* Share row */
    .share-row {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-top: 2.5rem;
      padding-top: 1.5rem;
      border-top: 1.5px solid var(--border);
      flex-wrap: wrap;
    }
    .share-label {
      font-family: 'DM Sans', sans-serif;
      font-size: 0.8rem;
      color: var(--text-light);
      font-weight: 500;
    }
    .share-btn {
      width: 36px; height: 36px;
      border-radius: 50%;
      border: 1.5px solid var(--border);
      background: var(--cream2);
      color: var(--text-mid);
      display: flex; align-items: center; justify-content: center;
      font-size: 0.9rem;
      cursor: pointer;
      transition: all 0.2s;
      text-decoration: none;
    }
    .share-btn:hover {
      background: var(--blush-light);
      border-color: var(--blush);
      color: var(--warm-brown);
      transform: translateY(-2px);
    }

    /* Author card */
    .author-card {
      display: flex;
      align-items: center;
      gap: 1.2rem;
      background: var(--cream2);
      border-radius: 16px;
      padding: 1.5rem;
      margin-top: 3rem;
      border: 1.5px solid var(--border);
    }
    .author-avatar {
      width: 56px; height: 56px;
      border-radius: 50%;
      background: var(--warm-brown);
      display: flex; align-items: center; justify-content: center;
      font-family: 'Playfair Display', serif;
      font-weight: 700;
      font-size: 1.3rem;
      color: var(--cream);
      flex-shrink: 0;
    }
    .author-name {
      font-family: 'Playfair Display', serif;
      font-size: 1rem;
      font-weight: 600;
      color: var(--text-dark);
    }
    .author-title {
      font-family: 'DM Sans', sans-serif;
      font-size: 0.8rem;
      color: var(--text-light);
      margin-top: 0.2rem;
    }

    /* ══════════════════════════════════════
       SIDEBAR
    ══════════════════════════════════════ */
    .sidebar-col {
      position: sticky;
      top: 80px;
    }

    .sidebar-block {
      background: var(--cream2);
      border-radius: 16px;
      padding: 1.5rem;
      margin-bottom: 1.8rem;
      border: 1.5px solid var(--border);
    }

    .sidebar-heading {
      font-family: 'DM Sans', sans-serif;
      font-size: 0.65rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: var(--text-light);
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .sidebar-heading::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--border);
    }

    .about-text {
      font-family: 'Lora', serif;
      font-size: 0.88rem;
      color: var(--text-mid);
      line-height: 1.75;
    }

    /* Themes */
    .themes-wrap {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }
    .theme-tag {
      font-family: 'DM Sans', sans-serif;
      font-size: 0.75rem;
      font-weight: 500;
      background: var(--cream);
      border: 1.5px solid var(--border);
      color: var(--text-mid);
      padding: 0.3rem 0.85rem;
      border-radius: 20px;
      cursor: pointer;
      transition: all 0.2s;
      text-decoration: none;
    }
    .theme-tag:hover {
      background: var(--blush-light);
      border-color: var(--blush);
      color: var(--warm-brown);
    }

    /* Popular posts */
    .popular-post {
      display: flex;
      gap: 0.85rem;
      padding: 0.85rem 0;
      border-bottom: 1px solid var(--border);
      text-decoration: none;
      transition: background 0.2s;
      border-radius: 8px;
      cursor: pointer;
    }
    .popular-post:last-child { border-bottom: none; }
    .popular-post:hover .pop-title { color: var(--blush); }
    .pop-img {
      width: 58px; height: 50px;
      border-radius: 9px;
      overflow: hidden;
      flex-shrink: 0;
      background: var(--cream3);
    }
    .pop-img img {
      width: 100%; height: 100%;
      object-fit: cover;
      filter: saturate(0.85);
    }
    .pop-title {
      font-family: 'Lora', serif;
      font-size: 0.85rem;
      color: var(--text-dark);
      line-height: 1.45;
      font-weight: 500;
      transition: color 0.2s;
    }
    .pop-meta {
      font-family: 'DM Sans', sans-serif;
      font-size: 0.7rem;
      color: var(--text-light);
      margin-top: 0.3rem;
    }

    /* ══════════════════════════════════════
       FOOTER
    ══════════════════════════════════════ */
    .site-footer {
      background: #2a1e12;
      color: rgba(250,246,240,0.7);
      padding: 0;
    }
    .footer-inner {
      max-width: 1200px;
      margin: 0 auto;
      padding: 2.8rem 2rem 1.8rem;
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 3rem;
      align-items: start;
    }
    .footer-brand {
      font-family: 'Playfair Display', serif;
      font-weight: 700;
      font-size: 1.3rem;
      color: var(--cream);
      margin-bottom: 0.4rem;
    }
    .footer-tagline {
      font-family: 'DM Sans', sans-serif;
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: rgba(250,246,240,0.4);
    }
    .footer-nav {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      align-items: flex-end;
    }
    .footer-nav a {
      font-family: 'DM Sans', sans-serif;
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: rgba(250,246,240,0.45);
      text-decoration: none;
      transition: color 0.2s;
    }
    .footer-nav a:hover { color: var(--blush-light); }
    .footer-bottom {
      max-width: 1200px;
      margin: 0 auto;
      padding: 1.2rem 2rem;
      border-top: 1px solid rgba(250,246,240,0.08);
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 1rem;
    }
    .footer-copy {
      font-family: 'DM Sans', sans-serif;
      font-size: 0.7rem;
      color: rgba(250,246,240,0.35);
    }
    .social-links {
      display: flex;
      gap: 0.65rem;
    }
    .social-link {
      width: 34px; height: 34px;
      border: 1px solid rgba(250,246,240,0.12);
      border-radius: 7px;
      display: flex; align-items: center; justify-content: center;
      color: rgba(250,246,240,0.4);
      font-size: 0.85rem;
      text-decoration: none;
      transition: all 0.2s;
    }
    .social-link:hover {
      border-color: var(--blush);
      color: var(--blush-light);
      background: rgba(212,144,122,0.1);
    }

    /* ══════════════════════════════════════
       PROGRESS BAR
    ══════════════════════════════════════ */
    .read-progress {
      position: fixed;
      top: 0; left: 0;
      height: 3px;
      background: linear-gradient(90deg, var(--blush), var(--sage));
      z-index: 999;
      width: 0%;
      transition: width 0.1s linear;
      border-radius: 0 2px 2px 0;
    }

    /* ══════════════════════════════════════
       BACK TO TOP
    ══════════════════════════════════════ */
    .back-top {
      position: fixed;
      bottom: 2rem; right: 2rem;
      width: 42px; height: 42px;
      border-radius: 50%;
      background: var(--warm-brown);
      color: var(--cream);
      border: none;
      display: flex; align-items: center; justify-content: center;
      font-size: 1rem;
      cursor: pointer;
      box-shadow: 0 4px 18px rgba(122,92,62,0.3);
      opacity: 0;
      transform: translateY(10px);
      transition: all 0.3s ease;
      z-index: 100;
    }
    .back-top.show { opacity: 1; transform: translateY(0); }
    .back-top:hover { background: var(--blush); transform: translateY(-3px); }

    /* ══════════════════════════════════════
       RESPONSIVE
    ══════════════════════════════════════ */
    @media (max-width: 860px) {
      .page-wrap {
        grid-template-columns: 1fr;
        gap: 2.5rem;
        padding: 2rem 1.25rem 4rem;
      }
      .sidebar-col {
        position: static;
      }
      .article-lead {
        grid-template-columns: 1fr;
      }
      .article-lead-right {
        flex-direction: row;
      }
      .article-lead-img { height: 200px; }
      .botanical-banner { height: 70px; }
      .footer-inner {
        grid-template-columns: 1fr;
        gap: 1.5rem;
      }
      .footer-nav { align-items: flex-start; flex-direction: row; flex-wrap: wrap; gap: 0.75rem; }
      .footer-bottom { flex-direction: column; align-items: flex-start; }
    }

    @media (max-width: 480px) {
      .article-title { font-size: 1.75rem; }
      .article-lead-right { flex-direction: column; }
      .inline-quote { font-size: 1.05rem; padding: 1.2rem 1.3rem; }
      .back-top { bottom: 1.2rem; right: 1.2rem; }
      .header-inner { padding: 0 1.25rem; }
    }

    /* ── Fade-in animation ── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .article-col { animation: fadeUp 0.7s ease 0.1s both; }
    .sidebar-col { animation: fadeUp 0.7s ease 0.25s both; }
  </style>
</head>
<body>

  <!-- Read progress bar -->
  <div class="read-progress" id="readProgress"></div>

  <!-- ── HEADER ── -->
  <header class="site-header" id="siteHeader">
    <div class="header-inner">
      <a href="https://decodingnewage.in/blogs.html" class="brand">
        <div class="brand-icon">
          <img src="DNATech_logo.png" alt="DNATech"
               onerror="this.style.display='none';this.parentElement.textContent='D'">
        </div>
        DNATech
      </a>
    </div>
  </header>

  <!-- ── BOTANICAL BANNER ── -->
  <div class="botanical-banner">
    <svg class="botanical-svg" viewBox="0 0 1200 90" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice">
      <rect width="1200" height="90" fill="#f5ede0"/>
      <!-- Left botanical cluster -->
      <ellipse cx="60" cy="55" rx="38" ry="18" fill="#c8ddc8" opacity="0.7" transform="rotate(-25 60 55)"/>
      <ellipse cx="45" cy="40" rx="28" ry="13" fill="#a8c8a8" opacity="0.5" transform="rotate(-40 45 40)"/>
      <ellipse cx="80" cy="65" rx="22" ry="10" fill="#b8d4b0" opacity="0.6" transform="rotate(-10 80 65)"/>
      <!-- Stems left -->
      <path d="M 30 90 Q 55 60 70 35" stroke="#7a9a7a" stroke-width="1.5" fill="none" opacity="0.7"/>
      <path d="M 20 90 Q 40 65 55 45" stroke="#8aaa8a" stroke-width="1.2" fill="none" opacity="0.5"/>
      <!-- Flowers left -->
      <circle cx="70" cy="35" r="5" fill="#d4907a" opacity="0.8"/>
      <circle cx="70" cy="35" r="9" fill="none" stroke="#d4907a" stroke-width="1" opacity="0.4"/>
      <circle cx="55" cy="45" r="3.5" fill="#e8b090" opacity="0.7"/>
      <circle cx="100" cy="28" r="4" fill="#c8a080" opacity="0.6"/>
      <ellipse cx="95" cy="50" rx="16" ry="8" fill="#d4bca0" opacity="0.4" transform="rotate(15 95 50)"/>

      <!-- Right botanical cluster -->
      <ellipse cx="1140" cy="50" rx="38" ry="18" fill="#c8ddc8" opacity="0.7" transform="rotate(25 1140 50)"/>
      <ellipse cx="1155" cy="38" rx="28" ry="13" fill="#a8c8a8" opacity="0.5" transform="rotate(40 1155 38)"/>
      <ellipse cx="1120" cy="62" rx="22" ry="10" fill="#b8d4b0" opacity="0.6" transform="rotate(10 1120 62)"/>
      <path d="M 1170 90 Q 1145 60 1130 35" stroke="#7a9a7a" stroke-width="1.5" fill="none" opacity="0.7"/>
      <path d="M 1180 90 Q 1160 65 1145 45" stroke="#8aaa8a" stroke-width="1.2" fill="none" opacity="0.5"/>
      <circle cx="1130" cy="35" r="5" fill="#d4907a" opacity="0.8"/>
      <circle cx="1130" cy="35" r="9" fill="none" stroke="#d4907a" stroke-width="1" opacity="0.4"/>
      <circle cx="1145" cy="45" r="3.5" fill="#e8b090" opacity="0.7"/>
      <circle cx="1100" cy="28" r="4" fill="#c8a080" opacity="0.6"/>
      <ellipse cx="1105" cy="52" rx="16" ry="8" fill="#d4bca0" opacity="0.4" transform="rotate(-15 1105 52)"/>

